<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZW_Tool.饮水提醒"
        x:CompileBindings="False"
        Title="饮水提醒"
        Width="380" Height="300"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        CanResize="False"
        Background="#F8FAFC">

    <StackPanel Margin="28" Spacing="20">
        <TextBlock Text="该喝水啦！" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center"/>

        <!-- 总体进度 -->
        <StackPanel Spacing="8">
            <ProgressBar x:Name="DrinkProgressBar" 
                         Height="14" 
                         Minimum="0"
                         Foreground="#10B981"
                         Background="#E5E7EB"
                         Margin="0,4,0,12"/>
            <TextBlock x:Name="DrinkProgressText" 
                       HorizontalAlignment="Center" FontSize="10"/>
        </StackPanel>

        <!-- 本次选择（滑块区域） -->
        <StackPanel Spacing="10">
            <TextBlock Text="本次喝多少？" 
                       FontSize="15" HorizontalAlignment="Center"/>
            <Grid ColumnDefinitions="90,*" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" 
                           Text="{Binding #slider.Value, StringFormat={}{0:0} ml}"
                           FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Slider x:Name="slider" Grid.Column="1"
                        Minimum="0" Maximum="500" Value="100"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Height="50"/>
            </Grid>
        </StackPanel>

        <Button Content="确定" 
                HorizontalAlignment="Center" 
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Width="80" Height="40"
                Click="OnConfirmClick"
                FontSize="15" FontWeight="Medium"/>
    </StackPanel>
</Window>
