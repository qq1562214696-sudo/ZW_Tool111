<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ZW_Tool"
        x:Class="ZW_Tool.文件打印器"
        x:DataType="local:文件打印器"
        Title="文件打印器 - 创宇极"
        Width="700" Height="550"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 提示文字（当列表为空时显示） -->
        <TextBlock Grid.Row="0" 
                   Text="拖拽文件或文件夹到下方列表区域"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   FontSize="14" 
                   Foreground="Gray"
                   IsVisible="{Binding Items.Count, Converter={x:Static local:ZeroToVisibleConverter.Instance}}"/>

        <!-- 文件列表（修复：移除 DataTemplate 中的 x:DataType，避免类型冲突） -->
        <ListBox Grid.Row="0" 
                 x:Name="FileListBox" 
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 KeyDown="OnListBoxKeyDown"
                 Background="Transparent"
                 DragDrop.AllowDrop="True">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="删除" Click="RemoveMenuItem_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="{Binding DisplayIndex}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding FullPath}" 
                                   Margin="10,0,0,0" 
                                   Foreground="Gray" 
                                   FontStyle="Italic"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Spacing="10" 
                    Margin="0,10">
            <Button Content="复制列表到剪贴板" 
                    Click="CopyListToClipboard_Click" 
                    Width="140" Height="32"/>
            <Button Content="扫描项目并生成全文件" 
                    Click="CopyProjectButton_Click" 
                    Width="160" Height="32"/>
            <Button Content="清空列表" 
                    Click="ClearList_Click" 
                    Width="100" Height="32"/>
        </StackPanel>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="2" 
                   x:Name="StatusText" 
                   Text="就绪" 
                   HorizontalAlignment="Center" 
                   Margin="0,10" 
                   FontSize="12" 
                   Foreground="#666"/>
    </Grid>
</Window>