<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>Settings</AssemblyName>
    <RootNamespace>ZW_Tool</RootNamespace>
    <Nullable>enable</Nullable>

    <!-- 只生成 .dll，禁止生成 .pdb / .deps.json / .runtimeconfig.json -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <GenerateDependencyFile>false</GenerateDependencyFile>
    <GenerateRuntimeConfigurationFiles>false</GenerateRuntimeConfigurationFiles>

    <!-- 禁用自动生成 AssemblyInfo 和 TargetFramework 特性，防止与主项目冲突 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.12" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.12" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ZW_Tool.csproj">
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <!-- 构建后自动复制 Settings.dll 到 Assets/Settings/，且只复制 .dll -->
  <Target Name="CopyToAssetsAfterBuild" AfterTargets="Build">
    <ItemGroup>
      <OutputFiles Include="$(TargetDir)Settings.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(OutputFiles)"
          DestinationFolder="$(MSBuildProjectDirectory)\..\..\..\Assets\Settings\"
          OverwriteReadOnlyFiles="true" />
    <Message Text="=== 已自动复制 Settings.dll 到 Assets\Settings\ ===" Importance="high" />
  </Target>

</Project>