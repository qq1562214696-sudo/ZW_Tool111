<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZW_Tool.QF">
    <StackPanel Margin="0,2,0,0" Spacing="2">
        <Expander Header="初始化（只需设置一次）" IsExpanded="True">
            <StackPanel Spacing="2">
                <TextBox x:Name="QF_UnityPathInput"
                         Watermark="Unity Assets路径（拖入或手动输入）"
                         Height="20" Padding="4,1"/>
                <Button Content="执行初始化"
                        Click="QF_初始化按钮_Click"/>
            </StackPanel>
        </Expander>

        <Expander Header="3ds Max 常用工具" IsExpanded="True">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2,0,0">
                <Button Grid.Row="0" Grid.Column="0"
                        Content="规范模型" Click="Max脚本"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Content="导出FBX(当前)" Click="Max脚本"/>
                <Button Grid.Row="0" Grid.Column="2"
                        Content="导出（贴图+FBX）" Click="Max脚本"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Content="选择多边面" Click="Max脚本"/>
                <Button Grid.Row="1" Grid.Column="1"
                        Content="选择法线翻转的面" Click="Max脚本"/>
                <Button Grid.Row="1" Grid.Column="2"
                        Content="面数检查" Click="Max脚本"/>
                <Button Grid.Row="2" Grid.Column="0"
                        Content="Mesh01_重命名" Click="Max脚本"/>
            </Grid>
        </Expander>

        <Expander Header="Unity 常用工具" IsExpanded="True">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2,0,0">
                <!-- <Button Grid.Row="0" Grid.Column="0"
                        Content="Unity 初始化（待实现）" Click="Unity脚本"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Content="打开 Avatar 编辑器" Click="Unity脚本"/>
                <Button x:Name="复制并导出Btn" Grid.Row="0" Grid.Column="2"
                        Content="复制选中并打开导出窗口" Click="Unity脚本"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Content="粘贴 Max 文件名到 Unity" Click="Unity脚本"/>
                <Button Grid.Row="1" Grid.Column="1"
                        Content="一键规范文件结构" Click="Unity脚本"/>
                <Button Grid.Row="1" Grid.Column="2"
                        Content="一键批量导出资产" Click="Unity脚本"/>
                <Button Grid.Row="2" Grid.Column="0"
                        Content="清空 Unity 中的 Max 名称列表" Click="Unity脚本"/> -->
            </Grid>
        </Expander>
    </StackPanel>
</UserControl>